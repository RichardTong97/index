<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GSG · Sistema de Vigilancias Médicas</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@500;600;700;800&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet">
<style>
/* ============ TOKENS ============ */
:root{
  --navy:#101A33;
  --navy-2:#17233F;
  --blue:#0B6FB8;
  --blue-deep:#0A5A97;
  --blue-light:#E8F2FB;
  --bg:#EFF3F7;
  --surface:#FFFFFF;
  --border:#DFE5EC;
  --text:#1B2333;
  --text-muted:#6B7686;
  --text-faint:#98A2B3;
  --green:#158A5F;
  --green-bg:#E4F5EE;
  --amber:#B9770E;
  --amber-bg:#FDF3DF;
  --red:#C43D4B;
  --red-bg:#FBE7E9;
  --purple:#6B4FCE;
  --purple-bg:#EFEAFB;
  --radius:10px;
  --shadow-sm:0 1px 2px rgba(16,26,51,.06);
  --shadow-md:0 6px 20px rgba(16,26,51,.08);
  --font-display:'Sora',sans-serif;
  --font-body:'Inter',sans-serif;
  --font-mono:'IBM Plex Mono',monospace;
}
*{box-sizing:border-box;}
html,body{margin:0;padding:0;}
body{
  font-family:var(--font-body);
  background:var(--bg);
  color:var(--text);
  -webkit-font-smoothing:antialiased;
  font-size:14px;
}
h1,h2,h3,h4{font-family:var(--font-display);margin:0;color:var(--navy);}
button{font-family:var(--font-body);cursor:pointer;}
a{color:inherit;}
::selection{background:var(--blue-light);}

/* ============ LAYOUT SHELL ============ */
.shell{display:flex;min-height:100vh;}

/* ---- Sidebar ---- */
.sidebar{
  width:230px;
  flex-shrink:0;
  background:linear-gradient(180deg,var(--navy) 0%, var(--navy-2) 100%);
  color:#C9D3E5;
  display:flex;
  flex-direction:column;
  position:sticky;
  top:0;
  height:100vh;
}
.brand{
  display:flex;align-items:center;gap:10px;
  padding:20px 18px 16px 18px;
  border-bottom:1px solid rgba(255,255,255,.08);
}
.brand-mark{
  width:34px;height:34px;border-radius:9px;
  background:linear-gradient(135deg,var(--blue) 0%, #34A0E8 100%);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;
  box-shadow:0 3px 10px rgba(11,111,184,.4);
}
.brand-mark svg{width:19px;height:19px;}
.brand-text{line-height:1.15;}
.brand-text .app-name{font-family:var(--font-display);font-weight:700;font-size:13.5px;color:#fff;}
.brand-text .app-sub{font-size:10.5px;color:#8291AE;letter-spacing:.04em;text-transform:uppercase;margin-top:2px;}

.nav-group-label{
  font-size:10px;letter-spacing:.09em;text-transform:uppercase;
  color:#5B6A8C;padding:18px 18px 6px 18px;font-weight:600;
}
.nav{list-style:none;margin:0;padding:4px 10px;}
.nav li{margin-bottom:2px;}
.nav a{
  display:flex;align-items:center;gap:10px;
  padding:9px 10px;border-radius:8px;
  text-decoration:none;color:#B7C2DA;font-size:13px;font-weight:500;
  transition:background .15s, color .15s;
  position:relative;
}
.nav a svg{width:16px;height:16px;flex-shrink:0;opacity:.85;}
.nav a:hover{background:rgba(255,255,255,.06);color:#fff;}
.nav a.active{background:rgba(11,111,184,.28);color:#fff;}
.nav a.active::before{
  content:"";position:absolute;left:-10px;top:6px;bottom:6px;width:3px;
  background:var(--blue);border-radius:0 3px 3px 0;
}
.nav .badge-count{
  margin-left:auto;background:rgba(255,255,255,.12);color:#fff;
  font-size:10.5px;padding:1px 6px;border-radius:20px;font-family:var(--font-mono);
}
.nav a.active .badge-count{background:var(--blue);}

.sidebar-footer{
  margin-top:auto;padding:14px 18px;border-top:1px solid rgba(255,255,255,.08);
  font-size:11px;color:#5B6A8C;
}

/* ---- Main column ---- */
.main{flex:1;min-width:0;display:flex;flex-direction:column;}

/* ---- Topbar ---- */
.topbar{
  background:var(--surface);border-bottom:1px solid var(--border);
  padding:0 26px;height:60px;
  display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:20;
}
.topbar-left{display:flex;align-items:center;gap:14px;}
.page-title{font-family:var(--font-display);font-size:17px;font-weight:700;color:var(--navy);}
.breadcrumb{font-size:11.5px;color:var(--text-faint);}
.breadcrumb b{color:var(--text-muted);font-weight:600;}

.role-switch{
  display:flex;background:var(--bg);border:1px solid var(--border);border-radius:999px;padding:3px;gap:2px;
}
.role-switch button{
  border:none;background:transparent;padding:7px 14px;border-radius:999px;
  font-size:12.5px;font-weight:600;color:var(--text-muted);white-space:nowrap;
  display:flex;align-items:center;gap:6px;transition:.15s;
}
.role-switch button svg{width:13px;height:13px;}
.role-switch button.active{background:var(--navy);color:#fff;box-shadow:var(--shadow-sm);}

.topbar-right{display:flex;align-items:center;gap:16px;}
.icon-btn{
  width:34px;height:34px;border-radius:8px;border:1px solid var(--border);background:var(--surface);
  display:flex;align-items:center;justify-content:center;position:relative;color:var(--text-muted);
}
.icon-btn svg{width:16px;height:16px;}
.icon-btn .dot{
  position:absolute;top:-3px;right:-3px;width:8px;height:8px;border-radius:50%;background:var(--red);
  border:2px solid var(--surface);
}
.user-chip{display:flex;align-items:center;gap:9px;padding-left:14px;border-left:1px solid var(--border);}
.avatar{
  width:32px;height:32px;border-radius:8px;background:linear-gradient(135deg,#0B6FB8,#4C8DF0);
  color:#fff;font-family:var(--font-display);font-weight:700;font-size:12.5px;
  display:flex;align-items:center;justify-content:center;
}
.user-meta{line-height:1.2;}
.user-meta .u-name{font-weight:600;font-size:12.5px;color:var(--navy);}
.user-meta .u-role{font-size:10.5px;color:var(--text-faint);}

/* ---- Content ---- */
.content{padding:22px 26px 60px 26px;}
.view{display:none;}
.view.active{display:block;animation:fadeIn .25s ease;}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px);}to{opacity:1;transform:translateY(0);}}

/* ============ COMPONENTS ============ */

/* KPI cards */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.kpi-card{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:16px 18px;box-shadow:var(--shadow-sm);position:relative;overflow:hidden;
}
.kpi-card .kpi-top{display:flex;justify-content:space-between;align-items:flex-start;}
.kpi-label{font-size:11.5px;color:var(--text-muted);font-weight:600;text-transform:uppercase;letter-spacing:.03em;}
.kpi-icon{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.kpi-icon svg{width:15px;height:15px;}
.kpi-value{font-family:var(--font-display);font-size:28px;font-weight:700;color:var(--navy);margin-top:10px;}
.kpi-sub{font-size:11.5px;color:var(--text-faint);margin-top:4px;}
.kpi-sub.up{color:var(--green);}
.kpi-sub.down{color:var(--red);}

/* Panels / cards */
.panel{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-sm);margin-bottom:18px;}
.panel-head{display:flex;align-items:center;justify-content:space-between;padding:16px 18px;border-bottom:1px solid var(--border);}
.panel-head h3{font-size:14px;font-weight:700;}
.panel-head .ph-sub{font-size:11.5px;color:var(--text-faint);font-weight:500;margin-top:2px;}
.panel-body{padding:18px;}

.grid-2{display:grid;grid-template-columns:1.4fr 1fr;gap:16px;}

/* Gauge (hero) */
.gauge-wrap{display:flex;align-items:center;gap:22px;}
.gauge{position:relative;width:132px;height:132px;flex-shrink:0;}
.gauge svg{transform:rotate(-90deg);}
.gauge-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;}
.gauge-center .g-num{font-family:var(--font-display);font-size:26px;font-weight:800;color:var(--navy);}
.gauge-center .g-lbl{font-size:9.5px;color:var(--text-faint);text-transform:uppercase;letter-spacing:.05em;}
.gauge-legend{display:flex;flex-direction:column;gap:9px;}
.gl-item{display:flex;align-items:center;gap:8px;font-size:12.5px;}
.gl-dot{width:9px;height:9px;border-radius:3px;flex-shrink:0;}
.gl-item b{margin-left:auto;font-family:var(--font-mono);font-size:12px;}

/* Bar chart (dept compliance) */
.bar-list{display:flex;flex-direction:column;gap:12px;}
.bar-row{display:grid;grid-template-columns:130px 1fr 42px;align-items:center;gap:10px;font-size:12.5px;}
.bar-row .b-label{color:var(--text-muted);font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.bar-track{background:var(--bg);border-radius:6px;height:9px;overflow:hidden;}
.bar-fill{height:100%;border-radius:6px;background:linear-gradient(90deg,var(--blue),#3FA0E8);}
.b-pct{font-family:var(--font-mono);font-weight:600;text-align:right;color:var(--navy);}

/* Donut mini */
.donut-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
.donut-card{text-align:center;}
.donut{width:74px;height:74px;border-radius:50%;margin:0 auto 8px auto;position:relative;}
.donut-lbl{font-size:11px;color:var(--text-muted);font-weight:600;}
.donut-val{font-family:var(--font-mono);font-size:11px;color:var(--text-faint);}

/* Table / Interactive-grid style */
.toolbar{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);gap:12px;flex-wrap:wrap;}
.filters{display:flex;gap:8px;flex-wrap:wrap;align-items:center;}
.select, .input-search{
  border:1px solid var(--border);background:var(--bg);border-radius:7px;
  padding:7px 10px;font-size:12.5px;color:var(--text);font-family:var(--font-body);
}
.input-search{display:flex;align-items:center;gap:6px;min-width:200px;background:var(--surface);}
.input-search svg{width:13px;height:13px;color:var(--text-faint);}
.input-search input{border:none;outline:none;font-size:12.5px;flex:1;background:transparent;}
.select{padding-right:22px;}

.btn{
  border:none;border-radius:7px;padding:8px 14px;font-size:12.5px;font-weight:600;
  display:inline-flex;align-items:center;gap:6px;white-space:nowrap;
}
.btn svg{width:13px;height:13px;}
.btn-primary{background:var(--blue);color:#fff;box-shadow:0 2px 6px rgba(11,111,184,.35);}
.btn-primary:hover{background:var(--blue-deep);}
.btn-ghost{background:var(--surface);color:var(--text-muted);border:1px solid var(--border);}
.btn-ghost:hover{background:var(--bg);}
.btn-sm{padding:5px 10px;font-size:11.5px;}

table.grid{width:100%;border-collapse:collapse;font-size:12.5px;}
table.grid thead th{
  text-align:left;padding:10px 14px;background:#F7F9FB;color:var(--text-muted);
  font-weight:600;font-size:10.8px;text-transform:uppercase;letter-spacing:.03em;
  border-bottom:1px solid var(--border);white-space:nowrap;
}
table.grid tbody td{padding:11px 14px;border-bottom:1px solid #F0F2F5;vertical-align:middle;white-space:nowrap;}
table.grid tbody tr:hover{background:var(--blue-light);}
table.grid tbody tr:last-child td{border-bottom:none;}
.cell-emp{display:flex;align-items:center;gap:9px;}
.mini-avatar{
  width:26px;height:26px;border-radius:7px;background:var(--bg);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;font-family:var(--font-display);
  font-size:10.5px;font-weight:700;color:var(--text-muted);flex-shrink:0;
}
.emp-name{font-weight:600;color:var(--navy);font-size:12.5px;}
.emp-code{font-family:var(--font-mono);font-size:10.5px;color:var(--text-faint);}

.badge{
  display:inline-flex;align-items:center;gap:5px;padding:3px 9px;border-radius:20px;
  font-size:10.8px;font-weight:700;letter-spacing:.01em;
}
.badge svg{width:9px;height:9px;}
.badge.completado{background:var(--green-bg);color:var(--green);}
.badge.proceso{background:var(--amber-bg);color:var(--amber);}
.badge.pendiente{background:var(--red-bg);color:var(--red);}
.badge.licencia{background:var(--purple-bg);color:var(--purple);}
.badge.retirado{background:#EDEFF3;color:#5A6478;}

.freq-tag{font-size:10px;font-family:var(--font-mono);color:var(--text-faint);background:var(--bg);padding:2px 6px;border-radius:5px;}

.evidence-icon{
  width:28px;height:28px;border-radius:7px;display:flex;align-items:center;justify-content:center;border:1px dashed var(--border);color:var(--text-faint);
}
.evidence-icon.ok{background:var(--green-bg);border:1px solid transparent;color:var(--green);cursor:pointer;}
.evidence-icon svg{width:13px;height:13px;}

.row-actions{display:flex;gap:6px;}
.icon-action{
  width:28px;height:28px;border-radius:7px;border:1px solid var(--border);background:var(--surface);
  display:flex;align-items:center;justify-content:center;color:var(--text-muted);
}
.icon-action svg{width:13px;height:13px;}
.icon-action:hover{background:var(--bg);color:var(--blue);}

.pager{display:flex;align-items:center;justify-content:space-between;padding:12px 18px;font-size:11.5px;color:var(--text-faint);}
.pager .p-btns{display:flex;gap:6px;}
.pager button{border:1px solid var(--border);background:var(--surface);border-radius:6px;width:26px;height:26px;color:var(--text-muted);}

/* Alerts panel (notifications) */
.alert-item{display:flex;gap:12px;padding:13px 18px;border-bottom:1px solid #F0F2F5;}
.alert-item:last-child{border-bottom:none;}
.alert-dot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex-shrink:0;}
.alert-dot.red{background:var(--red);} .alert-dot.amber{background:var(--amber);}
.alert-title{font-size:12.5px;font-weight:600;color:var(--navy);}
.alert-desc{font-size:11.5px;color:var(--text-muted);margin-top:2px;}
.alert-time{font-size:10.5px;color:var(--text-faint);margin-left:auto;white-space:nowrap;}

/* Legend note strip */
.rule-strip{
  display:flex;gap:10px;align-items:flex-start;background:var(--blue-light);border:1px solid #CFE4F7;
  border-radius:var(--radius);padding:12px 16px;font-size:12px;color:var(--blue-deep);margin-bottom:18px;
}
.rule-strip svg{width:15px;height:15px;flex-shrink:0;margin-top:1px;}
.rule-strip b{font-weight:700;}

/* Form (modal) */
.overlay{
  position:fixed;inset:0;background:rgba(16,26,51,.5);backdrop-filter:blur(2px);
  display:none;align-items:flex-start;justify-content:center;padding:40px 20px;z-index:100;overflow:auto;
}
.overlay.open{display:flex;}
.modal{
  background:var(--surface);border-radius:14px;max-width:760px;width:100%;box-shadow:0 20px 60px rgba(16,26,51,.3);
  overflow:hidden;
}
.modal-head{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:flex-start;background:linear-gradient(180deg,#FBFCFE,#fff);}
.modal-head h3{font-size:15.5px;}
.modal-head .mh-sub{font-size:11.5px;color:var(--text-faint);margin-top:3px;}
.modal-close{width:30px;height:30px;border:1px solid var(--border);border-radius:8px;background:var(--surface);display:flex;align-items:center;justify-content:center;color:var(--text-muted);}
.modal-close svg{width:14px;height:14px;}
.modal-body{padding:20px 22px;max-height:62vh;overflow:auto;}
.modal-foot{padding:14px 22px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;background:#FAFBFC;}

.fieldset-label{font-size:10.8px;font-weight:700;color:var(--blue-deep);text-transform:uppercase;letter-spacing:.05em;margin:18px 0 10px 0;display:flex;align-items:center;gap:7px;}
.fieldset-label:first-child{margin-top:0;}
.fieldset-label::after{content:"";flex:1;height:1px;background:var(--border);}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px 14px;}
.form-grid.cols-3{grid-template-columns:1fr 1fr 1fr;}
.field{display:flex;flex-direction:column;gap:5px;}
.field.full{grid-column:1/-1;}
.field label{font-size:11.5px;font-weight:600;color:var(--text-muted);}
.field label .req{color:var(--red);}
.field input, .field select, .field textarea{
  border:1px solid var(--border);border-radius:7px;padding:8px 10px;font-size:12.5px;
  font-family:var(--font-body);background:var(--surface);color:var(--text);
}
.field input:disabled{background:var(--bg);color:var(--text-faint);}
.field .hint{font-size:10.5px;color:var(--text-faint);}
.field .hint.calc{color:var(--blue-deep);font-weight:600;}
.upload-box{
  border:1.5px dashed var(--border);border-radius:9px;padding:16px;display:flex;align-items:center;gap:12px;
  background:var(--bg);
}
.upload-box svg{width:22px;height:22px;color:var(--blue);flex-shrink:0;}
.upload-box .u-title{font-size:12.5px;font-weight:600;color:var(--navy);}
.upload-box .u-sub{font-size:11px;color:var(--text-faint);}

/* Empty states */
.empty-note{padding:30px;text-align:center;color:var(--text-faint);font-size:12.5px;}

/* Responsive */
@media(max-width:1100px){
  .kpi-row{grid-template-columns:repeat(2,1fr);}
  .grid-2{grid-template-columns:1fr;}
  .form-grid, .form-grid.cols-3{grid-template-columns:1fr 1fr;}
}
@media(max-width:720px){
  .sidebar{display:none;}
  .kpi-row{grid-template-columns:1fr;}
  .form-grid, .form-grid.cols-3{grid-template-columns:1fr;}
}
</style>
</head>
