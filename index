<script>
// ---------- Navigation ----------
const navLinks = document.querySelectorAll('.nav-link');
const views = document.querySelectorAll('.view');
const pageTitle = document.getElementById('pageTitle');
const crumbCurrent = document.getElementById('crumbCurrent');
const roleButtons = document.querySelectorAll('.role-switch button');
const userAvatar = document.getElementById('userAvatar');
const userName = document.getElementById('userName');
const userRole = document.getElementById('userRole');

const titles = {
  'v-dashboard': ['Dashboard de Cumplimiento','Gerencia'],
  'v-ehs': ['Bandeja de Preparación','Preparador EHS'],
  'v-enf': ['Ejecución de Vigilancias','Enfermería'],
  'v-cert': ['Certificados de Salud','Módulos'],
  'v-vision': ['Evaluaciones Visuales','Módulos'],
  'v-resp': ['Programa Respiratorio','Módulos'],
  'v-alertas': ['Notificaciones y Alertas','Sistema']
};

const roleProfiles = {
  gerente: {name:'Richard Quispe', role:'Gerente · Producción', initials:'RQ'},
  ehs: {name:'Angela Barrenechea', role:'Preparadora EHS', initials:'AB'},
  enfermero: {name:'Angel Ramírez Díaz', role:'Enfermero Ocupacional', initials:'AR'}
};

function showView(id){
  views.forEach(v=>v.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  navLinks.forEach(l=>l.classList.remove('active'));
  const link = document.querySelector(`.nav-link[data-view="${id}"]`);
  if(link) link.classList.add('active');
  pageTitle.textContent = titles[id][0];
  crumbCurrent.textContent = titles[id][1];
}

function setRole(role){
  roleButtons.forEach(b=>b.classList.toggle('active', b.dataset.role===role));
  const p = roleProfiles[role];
  userAvatar.textContent = p.initials;
  userName.textContent = p.name;
  userRole.textContent = p.role;
}

navLinks.forEach(link=>{
  link.addEventListener('click', e=>{
    e.preventDefault();
    showView(link.dataset.view);
    if(link.dataset.role && link.dataset.role !== 'all'){ setRole(link.dataset.role); }
  });
});

roleButtons.forEach(btn=>{
  btn.addEventListener('click', ()=>{
    setRole(btn.dataset.role);
    if(btn.dataset.role==='gerente') showView('v-dashboard');
    if(btn.dataset.role==='ehs') showView('v-ehs');
    if(btn.dataset.role==='enfermero') showView('v-enf');
  });
});

// ---------- Modals ----------
function openModal(id){ document.getElementById(id).classList.add('open'); }
function closeModal(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.overlay').forEach(ov=>{
  ov.addEventListener('click', e=>{ if(e.target===ov) ov.classList.remove('open'); });
});

// ---------- Regla VDRL + 1 año ----------
function calcVencimiento(){
  const val = document.getElementById('vdrlDate').value;
  const out = document.getElementById('vencCalc');
  if(!val){ out.value='—'; return; }
  const d = new Date(val);
  d.setFullYear(d.getFullYear()+1);
  out.value = d.toLocaleDateString('es-PE',{day:'2-digit',month:'2-digit',year:'numeric'});
}
</script>
</body>
</html>
